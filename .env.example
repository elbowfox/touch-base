# TouchBase Environment Variables
# Copy to .env.local and fill in your values

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://touch-base.vercel.app

# OnchainKit API key (from https://portal.cdp.coinbase.com)
NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# Network: "mainnet" or "testnet" (default: testnet)
NEXT_PUBLIC_NETWORK=testnet

# Kindness Points contract address (deploy your own or use testnet)
NEXT_PUBLIC_KINDNESS_CONTRACT_ADDRESS=

# Farcaster domain association (from https://warpcast.com/~/developers)
# These enable the .well-known/farcaster.json endpoint
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=
