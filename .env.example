# touch-base — Farcaster Mini App Registration
# Copy this file to .env.local and fill in the values

# ─────────────────────────────────────────────
# Required: App metadata
# ─────────────────────────────────────────────

# App name displayed in Farcaster (max 32 characters)
NEXT_PUBLIC_APP_NAME=

# The entry URL for your Mini App (must use HTTPS in production)
NEXT_PUBLIC_APP_HOME_URL=

# Public URL of a 1024×1024px PNG icon with no alpha channel
NEXT_PUBLIC_APP_ICON_URL=

# Your app's domain without https:// (e.g. myapp.example.com)
NEXT_PUBLIC_CANONICAL_DOMAIN=

# ─────────────────────────────────────────────
# Optional: Additional metadata
# ─────────────────────────────────────────────

# Short description of your app
NEXT_PUBLIC_APP_DESCRIPTION=

# Tagline (short phrase, shown in some clients)
NEXT_PUBLIC_APP_TAGLINE=

# URL of a 200×200px splash image shown while the app loads
NEXT_PUBLIC_APP_SPLASH_IMAGE_URL=

# Hex background color for the splash screen (e.g. #0000FF)
NEXT_PUBLIC_APP_SPLASH_BG_COLOR=#ffffff

# URL of a 1200×630px hero image for social previews
NEXT_PUBLIC_APP_HERO_IMAGE_URL=

# Webhook URL to receive Mini App event notifications
NEXT_PUBLIC_APP_WEBHOOK_URL=

# ─────────────────────────────────────────────
# Required for a valid manifest: Account Association
# Generated via Warpcast Developer Tools:
#   Settings → Advanced → Developer Mode → ON
#   Settings → Developer → Domains → enter domain → Generate
# Or via https://build.top/manifest
# ─────────────────────────────────────────────

FARCASTER_ACCOUNT_ASSOCIATION_HEADER=
FARCASTER_ACCOUNT_ASSOCIATION_PAYLOAD=
FARCASTER_ACCOUNT_ASSOCIATION_SIGNATURE=
