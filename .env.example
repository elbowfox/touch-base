# TouchBase Environment Variables
# Copy to .env.local and fill in your values

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://touch-base.vercel.app

# OnchainKit API key (from https://portal.cdp.coinbase.com)
NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# Network: "mainnet" or "testnet" (default: testnet)
NEXT_PUBLIC_NETWORK=testnet

# Kindness Points contract address (deploy your own or use testnet)
NEXT_PUBLIC_KINDNESS_CONTRACT_ADDRESS=

# Farcaster domain association (from https://warpcast.com/~/developers)
# These enable the .well-known/farcaster.json endpoint
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=

# ─────────────────────────────────────────────
# SoulCraft AI Configuration
# ─────────────────────────────────────────────

# Anthropic API key — powers agent generation (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Stripe — for SoulCraft monetization (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (create in Stripe dashboard → Products)
# Forge plan: $9/month
STRIPE_FORGE_PRICE_ID=
NEXT_PUBLIC_STRIPE_FORGE_PRICE_ID=

# Genesis plan: $29/month
STRIPE_GENESIS_PRICE_ID=
NEXT_PUBLIC_STRIPE_GENESIS_PRICE_ID=

# Studio plan: $99/month
STRIPE_STUDIO_PRICE_ID=
NEXT_PUBLIC_STRIPE_STUDIO_PRICE_ID=

# Stripe webhook secret (from Stripe CLI or dashboard)
STRIPE_WEBHOOK_SECRET=
